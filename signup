<title>NextUp All Sports | Waitlist</title>
<style>
:root{--bg:#02040a;--card:#07101d;--line:rgba(255,255,255,.12);--blue:#0877ff;--cyan:#20d8ff;--text:#f8fbff;--muted:#9aaabe;--glow:0 0 42px rgba(8,119,255,.38)}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,Arial,sans-serif;background:radial-gradient(circle at 15% 5%,rgba(8,119,255,.28),transparent 28%),linear-gradient(180deg,#010207,#050916 55%,#010207);color:var(--text)}a{text-decoration:none;color:inherit}
.nav{position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:space-between;padding:16px 6vw;background:rgba(2,4,10,.84);backdrop-filter:blur(16px);border-bottom:1px solid var(--line)}.nav img{height:54px}.navlinks{display:flex;gap:24px;color:var(--muted);font-weight:800}
.btn{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:14px 22px;background:linear-gradient(135deg,var(--blue),#004bff);border:1px solid rgba(255,255,255,.16);box-shadow:var(--glow);font-weight:950;color:white;cursor:pointer}.ghost{background:rgba(255,255,255,.045);box-shadow:none}
.hero{min-height:86vh;display:grid;grid-template-columns:1.05fr .95fr;gap:44px;align-items:center;padding:72px 6vw 48px}.badge{display:inline-flex;padding:9px 14px;border-radius:999px;border:1px solid rgba(32,216,255,.35);background:rgba(8,119,255,.12);color:#c9efff;text-transform:uppercase;letter-spacing:.12em;font-size:12px;font-weight:950}
h1{font-size:clamp(52px,8vw,112px);line-height:.88;letter-spacing:-.07em;margin:24px 0 20px}.blue{color:var(--blue)}.lead{font-size:clamp(18px,2.25vw,28px);line-height:1.35;color:#dce9f9;max-width:780px;margin:0}.actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:30px}
.logoBox{border:1px solid rgba(32,216,255,.25);border-radius:34px;padding:22px;background:linear-gradient(145deg,rgba(8,119,255,.18),rgba(255,255,255,.03));box-shadow:var(--glow)}.logoBox img{width:100%;display:block;border-radius:24px;background:#000}
.quick{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:28px}.quick div,.feature,.shot,form{background:linear-gradient(180deg,rgba(13,22,37,.92),rgba(4,8,16,.92));border:1px solid var(--line);border-radius:24px}.quick div{padding:18px}.quick b{display:block;font-size:22px}.quick span{color:var(--muted);font-size:13px;font-weight:750}
section{padding:70px 6vw}.title{font-size:clamp(34px,5vw,64px);line-height:.98;letter-spacing:-.045em;margin:0 0 14px}.sub{color:var(--muted);font-size:19px;line-height:1.55;max-width:800px}
.features{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:34px}.feature{padding:26px}.feature .ico{font-size:34px;margin-bottom:16px}.feature h3{font-size:24px;margin:0 0 10px}.feature p{color:var(--muted);line-height:1.45;margin:0}
.showcase{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:34px}.shot{overflow:hidden;box-shadow:0 0 28px rgba(8,119,255,.14)}.shot img{width:100%;display:block}.cap{padding:18px 20px}.cap b{font-size:21px}.cap p{color:var(--muted);margin:8px 0 0;line-height:1.45}
.wait{display:grid;grid-template-columns:1fr 1fr;gap:34px;align-items:start;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:radial-gradient(circle at 80% 20%,rgba(8,119,255,.2),transparent 32%)}form{padding:28px;box-shadow:var(--glow)}label{display:block;margin:16px 0 8px;color:#dcecff;font-weight:900}input{width:100%;padding:15px 16px;border-radius:15px;background:#050914;border:1px solid rgba(255,255,255,.16);color:white;font-size:16px;outline:none}.checks{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.check{display:flex;gap:10px;align-items:center;padding:13px 12px;border-radius:15px;background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.14);font-weight:850;color:#dce8f8;cursor:pointer}.check input{width:18px;height:18px;accent-color:var(--blue)}.check:has(input:checked){border-color:rgba(32,216,255,.7);background:rgba(8,119,255,.16)}
.success{display:none;margin-top:16px;padding:15px;border-radius:16px;color:#b9ffe6;background:rgba(0,255,160,.12);border:1px solid rgba(0,255,160,.34);font-weight:900}footer{padding:34px 6vw;display:flex;justify-content:space-between;gap:20px;color:var(--muted);border-top:1px solid var(--line)}footer img{height:44px}
@media(max-width:980px){.hero,.wait,.showcase{grid-template-columns:1fr}.features{grid-template-columns:repeat(2,1fr)}.navlinks{display:none}}@media(max-width:640px){.quick,.features,.checks{grid-template-columns:1fr}.nav img{height:42px}footer{flex-direction:column}.hero{padding-top:46px}}
</style>
</head>
